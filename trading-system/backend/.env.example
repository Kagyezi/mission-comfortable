# ─── Database ────────────────────────────────────────────
# Async URL used by the FastAPI app
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/trading_db

# Sync URL used by Alembic for migrations
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:password@localhost:5432/trading_db

# ─── MT5 Broker (Phase 2) ────────────────────────────────
MT5_LOGIN=0
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server

# ─── API ─────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ─── Trading Defaults ────────────────────────────────────
DEFAULT_PAIR=EURUSD
DEFAULT_TIMEFRAME=M15
TRADING_MODE=paper
