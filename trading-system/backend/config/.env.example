# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Database
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/trading_system

# MetaTrader 5 credentials (fill in Phase 2)
MT5_LOGIN=0
MT5_PASSWORD=your_mt5_password
MT5_SERVER=your_broker_server

# Environment
ENV=development
